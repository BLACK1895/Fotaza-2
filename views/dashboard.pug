doctype html
html
  head
    title Muro de Fotos - Fotaza 2
    link(rel="stylesheet", href="/css/style.css")
  body
    .dashboard-header
      h1 FOTAZA 2 📸
      .user-info
        span Hola, #{username}! 
        a(href="/logout" style="margin-left: 20px; color: #fff; font-size: 13px;") [ Salir ]
        // --- SECCIÓN DAR DE BAJA CUENTA ---
        form(action="/eliminar-cuenta" method="POST" style="display: inline-block; margin-left: 20px;" onsubmit="return confirm('¿Estás completamente seguro de que querés dar de baja tu cuenta? Esta acción eliminará permanentemente tu perfil y todas tus fotos del muro.');")
          button(type="submit" style="background: none; border: none; color: #ff4d4d; font-size: 13px; cursor: pointer; text-decoration: underline; padding: 0;") [ Dar de baja cuenta ]
    
    .dashboard-wrapper
      .upload-card
        h3 Compartir Momento
        form(action="/publicar" method="POST" enctype="multipart/form-data")
          .form-group
            input.minimal-input(type="text" name="titulo" required placeholder="Título de la foto")
          .form-group
            textarea(name="descripcion" rows="2" placeholder="¿Qué está pasando en esta imagen?")
          .form-group
            label(style="font-size: 12px; color: #777; display: block; margin-bottom: 5px;") Licencia:
            select(name="tipo_licencia")
              option(value="copyright") © Con Copyright
              option(value="sin_copyright") CC0 Uso Libre
          .form-group(style="margin-top: 15px; margin-bottom: 25px;")
             input#foto-input(type="file" name="foto" accept="image/*" required style="display: none;" onchange="updateFileName()")
             label.file-label(for="foto-input") 📸 Seleccionar Foto
             span#file-name(style="display: block; margin-top: 8px; font-size: 13px; color: #555; font-style: italic;") Ningún archivo seleccionado

          button.btn-boca(type="submit") Subir al Muro
             
        script.
          function updateFileName() {
            const input = document.getElementById('foto-input');
            const label = document.getElementById('file-name');
            if(input.files && input.files.length > 0) {
              label.innerText = "Archivo listo: " + input.files[0].name;
            } else {
              label.innerText = "Ningún archivo seleccionado";
            }
          }

      // --- BARRA DE BÚSQUEDA ---
      form(action="/dashboard" method="GET" style="display: flex; gap: 10px; margin-bottom: 20px; margin-top: 20px;")
        input.minimal-input(type="text" name="search" placeholder="🔍 Buscar publicaciones..." style="flex-grow: 1; margin-bottom: 0;")
        button.btn-boca(type="submit" style="width: auto; padding: 0 20px; margin-top: 0;") Buscar

      h2(style="color: #fff; margin-bottom: 20px; font-size: 18px; text-transform: uppercase;") Últimas Fotos Compartidas
      
      if posts.length > 0
        each post in posts
          .post-card
            .post-header
              div
                h3 #{post.titulo}
                a(href=`/usuario/${post.autor_id}` style="text-decoration: none;")
                  span.post-username por @#{post.username}
              span.license-badge #{post.tipo_licencia === 'copyright' ? 'Copyright' : 'Libre'}
            
            img(src=post.ruta_archivo alt=post.titulo)
            
            .post-content
              p.post-description #{post.descripcion}
              
              // --- FORMULARIO DE LIKES ---
              form(action=`/publicacion/${post.id}/like` method="POST" style="margin-top: 12px;")
                button(type="submit" style="background: none; border: none; font-size: 18px; cursor: pointer; display: flex; align-items: center; gap: 6px; padding: 0;")
                  span 💙
                  span(style="color: #0c00b3; font-size: 14px; font-weight: bold;") #{post.total_likes || 0} Me gusta

              // --- SECCIÓN DE COMENTARIOS ---
              .comments-section(style="margin-top: 20px; border-top: 1px solid #f7f7f7; padding-top: 15px;")
                
                // 📖 Lista de comentarios existentes
                if post.comentarios && post.comentarios.length > 0
                  .comments-list(style="margin-bottom: 15px; max-height: 200px; overflow-y: auto;")
                    each com in post.comentarios
                      .comment-item(style="margin-bottom: 8px; background: #fcfcfc; padding: 6px 10px; border-radius: 4px;")
                        span(style="color: #001677; font-size: 12px; font-weight: bold; display: block;") @#{com.username}
                        p(style="color: #000000; margin: 2px 0 0 0; font-size: 13px;") #{com.contenido}
                else
                  p(style="color: #555; font-size: 12px; font-style: italic; margin-bottom: 15px;") No hay comentarios en esta foto.
                
                // ✍️ Caja para comentar
                form(action=`/publicacion/${post.id}/comentario` method="POST" style="display: flex; gap: 10px; margin-bottom: 15px;")
                  input.minimal-input(type="text" name="contenido" placeholder="Escribe un comentario..." required style="margin-bottom: 0; flex-grow: 1; padding: 8px; font-size: 13px; color: #fff;")
                  button.btn-boca(type="submit" style="width: auto; margin-top: 0; padding: 0 15px; font-size: 13px;") Comentar
            
            .post-footer
              span Publicado el #{new Date(post.created_at).toLocaleDateString()}
      else
        .upload-card(style="text-align: center;")
          p(style="color: #777;") No hay fotos aún. ¡Inaugurá el muro!